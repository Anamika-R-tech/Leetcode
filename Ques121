class Solution {
    public int maxProfit(int[] price) {
        int bp=price[0];
        int profit=0;
        for(int i=1;i<price.length;i++){
            bp=Math.min(price[i], bp);
            int sp=price[i];
            profit=Math.max(profit, (sp-bp));
        }
        return profit;
    }
}
